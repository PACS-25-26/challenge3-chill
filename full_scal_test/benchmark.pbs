#!/bin/bash
#PBS -N laplace_tests
#PBS -q cpu
#PBS -l select=1:ncpus=16:mpiprocs=4
#PBS -l walltime=00:30:00
#PBS -j oe
#PBS -o /work/u10833012/challenge3-chill/benchmark.out
#PBS -e /work/u10833012/challenge3-chill/benchmark.err

# Move to the directory where the job was submitted from
cd "$PBS_O_WORKDIR"

# Load the required Software Modules via Spack
source /software/spack/share/spack/setup-env.sh
spack load gcc@15.2.0
spack load intel-oneapi-tbb@2022.3.0
spack load openmpi@5.0.8

# Compile the code 
make clean > build.log 2>&1
make >> build.log 2>&1

# Run your benchmark script
./full_scal_test/run_full_scal_test.sh >> build.log 2>&1